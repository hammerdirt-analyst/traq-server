# TRAQ server baseline environment

TRAQ_API_KEY=demo-key
TRAQ_STORAGE_ROOT=./local_data
TRAQ_ARTIFACT_BACKEND=local
# Required when TRAQ_ARTIFACT_BACKEND=gcs
# TRAQ_GCS_BUCKET=your-artifact-bucket
# Optional prefix inside the bucket
# TRAQ_GCS_PREFIX=traq
TRAQ_ENABLE_DISCOVERY=true
TRAQ_DATABASE_URL=postgresql+psycopg://traq_app:change-this-password@127.0.0.1:5432/traq_demo
TRAQ_DISCOVERY_PORT=8000
TRAQ_DISCOVERY_NAME=TRAQ Server

# Required for extractor and report generation paths
OPENAI_API_KEY=replace-me
TRAQ_OPENAI_MODEL=gpt-4o-mini
TRAQ_OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
